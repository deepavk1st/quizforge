{
  "name": "quizforge",
  "version": "2.0.0",
  "description": "Programmatic quiz video generator with AI TTS narration, 8 themes, bulk generation, and subscribe CTA scenes",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev":       "concurrently -n \"api,web\" -c \"cyan.bold,magenta.bold\" \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "dev:api":   "npm run dev --workspace=apps/api",
    "dev:web":   "npm run dev --workspace=apps/web",
    "studio":    "npm run studio --workspace=apps/renderer",
    "test":      "node --test --test-reporter=spec \"tests/unit/*.test.js\" \"tests/integration/*.test.js\" \"tests/e2e/*.test.js\"",
    "test:unit": "node --test --test-reporter=spec \"tests/unit/*.test.js\"",
    "test:int":  "node --test --test-reporter=spec \"tests/integration/*.test.js\"",
    "test:e2e":  "node --test --test-reporter=spec \"tests/e2e/*.test.js\"",
    "repair":    "node tests/repair/repair-questions.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
